# secrets
.credentials.json
settings.local.json
*.local.json

# machine-specific config (ship settings.example.json instead)
# settings.json holds live API keys in `env` — it and EVERY backup of it must stay local.
# Glob, not exact names: a one-off backup (settings.json.pre-hookfix.bak) once slipped
# past the exact-name entries and would have been committed with live keys.
settings.json
settings.json*.bak
settings.json.*
# Orca / environment machine-local runtime config
policy-limits.json
remote-settings.json

# third-party plugins (own repos)
plugins/

# vendored third-party skill content (own repos) — fetched locally by
# /update vendor <name>, never committed; see docs/THIRD_PARTY_SKILLS.md
skills/design/vendor/

# external symlinked skills
skills/improve
skills/impeccable
# Orca-managed external skills (symlinks to ~/.agents/skills/)
skills/computer-use
skills/orca-cli
skills/orchestration
# emilkowalski/skills — animation/design-eng taste rules (npx skills@latest add emilkowalski/skills)
skills/emil-design-eng
skills/animation-vocabulary
skills/review-animations
# trim-* = new name (after reinstall from holland-built/trim)
skills/trim
skills/trim-audit
skills/trim-debt
skills/trim-gain
skills/trim-help
skills/trim-review

# interface-design = externally managed by npx skills@latest (symlink to ~/.agents/)
skills/interface-design

# runtime / session
projects/
sessions/
session-data/
session-env/
shell-snapshots/
file-history/
ide/
metrics/

# caches
cache/
paste-cache/
image-cache/

# personal / private (project-scoped memories live in projects/ — already ignored)
memory/compile-manifest.json
memory/facts/

# ephemeral work
plans/
advisor-plans/
tasks/
proposals/
brainstorms/

# archives / trash
_archive_*/
backups/
.skill-trash/
skills/*/_claude_bak/
skills/learned/

# logs
history.jsonl
*.log

# runtime markers
.pending-tasks.md
learnings.md
.caveman-active
.lockstep-active
.worktree-active/
.last-cleanup
.last-update-result.json
.learnings-turn-counter
.reflect-turn-counter
mcp-health-cache.json
mcp-needs-auth-cache.json

# OS
.DS_Store
.agents/

# Claude Code runtime state (created when ~/.claude itself is opened as a project)
.claude.json
.claude/
chrome/
debug/

# no-yolo local deny-list (company names / private hostnames — never published)
.no-yolo-deny.txt

# archify — npx-installed under .agents/; defensive entry
skills/archify

# --md-only backup of CLAUDE.md (restored by full setup)
CLAUDE.md.pre-md-only
