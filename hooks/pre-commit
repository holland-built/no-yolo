#!/usr/bin/env bash
# Pre-commit hook for ~/.claude (holland-built/no-yolo) — TRACKED SOURCE.
# Installed into .git/hooks/pre-commit by setup.sh. Blocks commits containing
# personal data, private-network/infra values, and terms from .no-yolo-deny.txt.

# Credential / personal patterns
PATTERNS="/Users/[a-zA-Z0-9_-]+|session: [a-f0-9-]{36}|password\s*[:=]|secret\s*[:=]|api[_-]?key\s*[:=]|AKIA[0-9A-Z]{16}"

# Private-network / internal-infra patterns — these leaked once (a self-hosted
# LAN IP, a tailnet host) and the credential patterns above didn't catch them.
# Docs must use placeholders (<your-host>, <port>), never real private values.
#   RFC1918 LAN IPs (192.168/16, 10/8, 172.16-31)
#   Tailscale CGNAT range (100.64/10)
#   Internal-only hostname TLDs (.internal .corp .lan .home + *.local hostnames)
# Mirrored by verify.sh check 8 (tracked-content scan) — if this changes, mirror it there.
INFRA_PATTERNS="192\.168\.[0-9]{1,3}\.[0-9]{1,3}|(^|[^0-9])10\.[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}|172\.(1[6-9]|2[0-9]|3[01])\.[0-9]{1,3}\.[0-9]{1,3}|100\.(6[4-9]|[7-9][0-9]|1[0-1][0-9]|12[0-7])\.[0-9]{1,3}\.[0-9]{1,3}|[a-z0-9-]+\.(internal|corp|lan|home)\b|[a-z0-9-]+\.[a-z0-9-]+\.local\b"

BLOCKED_FILES=(
  "memory/facts/"
  "memory/compile-manifest.json"
  "brainstorms/"
  "plans/"
  "proposals/"
  "settings.json"
  "settings.local.json"
  "history.jsonl"
  "projects/"
  "sessions/"
  "cache/"
  "paste-cache/"
)

echo "🔍 no-yolo pre-commit: scanning for personal data..."

# 1 — Block personal dirs (only additions/modifications — allow deletions)
STAGED_AM=$(git diff --cached --name-status | grep -E "^[AM]" | awk '{print $2}')
for pattern in "${BLOCKED_FILES[@]}"; do
  if echo "$STAGED_AM" | grep -q "^$pattern"; then
    echo "❌ BLOCKED: personal path being added/modified: $pattern"
    echo "   Run: git reset HEAD <file> to unstage"
    exit 1
  fi
done

# added lines only, minus lines that are themselves regex patterns
ADDED=$(git diff --cached | grep -E "^\+" | grep -vE "^\+\+\+" | grep -v "\[a-zA-Z" | grep -v "\[a-z0-9")

# 2 — Block personal / credential content
MATCHES=$(echo "$ADDED" | grep -E "$PATTERNS")
if [ -n "$MATCHES" ]; then
  echo "❌ BLOCKED: personal data pattern found in diff:"
  echo "$MATCHES"
  echo ""
  echo "Fix the content above, then re-stage and commit."
  exit 1
fi

# 3 — Block private-network / internal-infra values (use placeholders in docs)
INFRA=$(echo "$ADDED" | grep -EI "$INFRA_PATTERNS")
if [ -n "$INFRA" ]; then
  echo "❌ BLOCKED: private network / internal infra value in diff:"
  echo "$INFRA"
  echo ""
  echo "Docs must use placeholders (<your-host>, <port>) — never real LAN IPs,"
  echo "tailnet addresses, or internal hostnames. Fix, re-stage, commit."
  exit 1
fi

# 4 — Block company / private terms from the local (gitignored) deny-list
DENY_FILE="$(git rev-parse --show-toplevel)/.no-yolo-deny.txt"
if [ -f "$DENY_FILE" ]; then
  TERMS=$(grep -vE '^\s*#|^\s*$' "$DENY_FILE" | paste -sd'|' -)
  if [ -n "$TERMS" ]; then
    DENIED=$(echo "$ADDED" | grep -iE "$TERMS")
    if [ -n "$DENIED" ]; then
      echo "❌ BLOCKED: term from .no-yolo-deny.txt (company/private) in diff:"
      echo "$DENIED"
      echo ""
      echo "These must never be published. Fix, re-stage, commit."
      echo "(Edit ~/.claude/.no-yolo-deny.txt to adjust the list.)"
      exit 1
    fi
  fi
fi

echo "✅ no-yolo pre-commit: clean"
exit 0
